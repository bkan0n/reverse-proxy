youngnebula.com {
	tls {
		dns cloudflare {env.YOUNGNEBULA_COM_CF_API_TOKEN}
	}
	reverse_proxy genjishimada-web:8080
}
*.youngnebula.com {
	tls {
		dns cloudflare {env.YOUNGNEBULA_COM_CF_API_TOKEN}
	}

	@api host api.youngnebula.com
	handle @api {
		reverse_proxy genjishimada-api:8000
	}

	@testapi host testapi.youngnebula.com
	handle @testapi {
		reverse_proxy genjishimada-api-dev:8000
	}

	@rabbitmq host rabbitmq.youngnebula.com
	handle @rabbitmq {
		reverse_proxy genjishimada-rabbitmq:15672
	}
}
