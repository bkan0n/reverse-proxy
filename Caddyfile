(auth_monitoring) {
	forward_auth oauth2-proxy:4180 {
		uri /oauth2/auth
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Uri {uri}
		header_up X-Forwarded-Proto {scheme}

		@unauthorized status 401
		handle_response @unauthorized {
			redir https://auth.bkan0n.com/oauth2/start?rd={scheme}://{host}{uri}
		}
	}
}

bkan0n.com {
	tls {
		dns cloudflare {env.BKAN0N_COM_CF_API_TOKEN}
	}
	reverse_proxy bkan0n:80
}
*.bkan0n.com {
	tls {
		dns cloudflare {env.BKAN0N_COM_CF_API_TOKEN}
	}

	@www host www.bkan0n.com
	handle @www {
		redir https://bkan0n.com{uri}
	}

	@auth host auth.bkan0n.com
	handle @auth {
		reverse_proxy oauth2-proxy:4180
	}

	@portal host portal.bkan0n.com
	handle @portal {
		reverse_proxy keycloak:8080
	}

	@status host status.bkan0n.com
	handle @status {
		reverse_proxy uptime-kuma:3001
	}

	@translate host translate.bkan0n.com
	handle @translate {
		reverse_proxy libretranslate:5000
	}

	@webhook host webhook.bkan0n.com
	handle @webhook {
		reverse_proxy webhook:8000
	}

	@prometheus host prometheus.bkan0n.com
	handle @prometheus {
		import auth_monitoring
		reverse_proxy prometheus:9090
	}

	@cadvisor host cadvisor.bkan0n.com
	handle @cadvisor {
		import auth_monitoring
		reverse_proxy cadvisor:8080
	}

	@grafana host grafana.bkan0n.com
	handle @grafana {
		reverse_proxy grafana:3000
	}

	@loki host loki.bkan0n.com
	handle @loki {
		import auth_monitoring
		reverse_proxy loki:3100
	}

	@alloy host alloy.bkan0n.com
	handle @alloy {
		import auth_monitoring
		reverse_proxy alloy:12345
	}

	@zerobyte host zerobyte.bkan0n.com
	handle @zerobyte {
		reverse_proxy zerobyte:4096
	}

	@dockhand host dockhand.bkan0n.com
	handle @dockhand {
		reverse_proxy dockhand:3000
	}
}

