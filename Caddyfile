genji.pk {
	tls {
		dns cloudflare {env.GENJI_PK_CF_API_TOKEN}
	}
	reverse_proxy genjishimada-web:8080
}

*.genji.pk {
	tls {
		dns cloudflare {env.GENJI_PK_CF_API_TOKEN}
	}

	############ PROD
	@www host www.genji.pk
	handle @www {
		redir https://genji.pk{uri}
	}

	@api host api.genji.pk
	handle @api {
		reverse_proxy genjishimada-api:8000
	}

	@rabbitmq host rabbitmq.genji.pk
	handle @rabbitmq {
		route {
			reverse_proxy genjishimada-rabbitmq:15672
		}
	}

	############ DEV
	@dev-web host dev.genji.pk
	handle @dev-web {
		route {
			reverse_proxy genjishimada-web-dev:8080
		}
	}

	@dev-api host dev-api.genji.pk
	handle @dev-api {
		reverse_proxy genjishimada-api-dev:8000
	}

	@dev-rabbitmq host dev-rabbitmq.genji.pk
	handle @dev-rabbitmq {
		route {
			reverse_proxy genjishimada-rabbitmq-dev:15672
		}
	}

	@db host db.genji.pk
	handle @db {
		route {
			reverse_proxy visualdb:80
		}
	}
}

